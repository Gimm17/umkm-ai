##
## UmkmAI — Environment Configuration
## Copy this file to .env and fill in the required values.
## Never commit your .env file to version control!
##

# -------------------------------------------------------
# Application
# -------------------------------------------------------
APP_NAME=UmkmAI
APP_ENV=production        # local | staging | production
APP_KEY=                  # Generate with: php artisan key:generate
APP_DEBUG=false           # Set to true only in development
APP_URL=http://localhost  # Your public domain e.g. https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error           # debug | info | warning | error

# -------------------------------------------------------
# Database — MySQL (production)
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql             # Use 'mysql' for Docker Compose, '127.0.0.1' for local
DB_PORT=3306
DB_DATABASE=umkm_ai
DB_USERNAME=umkmai
DB_PASSWORD=              # Set a strong password!
DB_ROOT_PASSWORD=         # MySQL root password (Docker only)

# Expose ports for local development (Docker only)
DB_PORT_EXPOSE=3306
REDIS_PORT_EXPOSE=6379

# -------------------------------------------------------
# Session
# -------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -------------------------------------------------------
# Cache & Queue
# -------------------------------------------------------
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# -------------------------------------------------------
# Redis
# -------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=redis          # Use 'redis' for Docker Compose, '127.0.0.1' for local
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------------------------------------
# Real-time Broadcasting (Soketi — self-hosted Pusher)
# -------------------------------------------------------
PUSHER_APP_ID=umkm-ai
PUSHER_APP_KEY=umkm-ai-key          # Change this to a random string
PUSHER_APP_SECRET=umkm-ai-secret    # Change this to a random string!
PUSHER_HOST=soketi        # Use 'soketi' for Docker, '127.0.0.1' for local
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1
SOKETI_DEBUG=0

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# -------------------------------------------------------
# 🤖 Anthropic Claude AI  (REQUIRED)
# Get your key at: https://console.anthropic.com
# -------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------
# 📱 WhatsApp Cloud API  (REQUIRED for WhatsApp)
# Setup at: https://developers.facebook.com
# -------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=your_random_verify_token_here   # Any random string you choose
WHATSAPP_APP_SECRET=

# -------------------------------------------------------
# 📸 Instagram Graph API  (REQUIRED for Instagram)
# Setup at: https://developers.facebook.com
# -------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=your_random_verify_token_here  # Any random string you choose
INSTAGRAM_APP_SECRET=

# -------------------------------------------------------
# Webhook Security
# -------------------------------------------------------
WEBHOOK_SKIP_VERIFY=false   # Set to true ONLY in local dev to skip signature check

# -------------------------------------------------------
# Mail (optional — for notifications)
# -------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Nginx
# -------------------------------------------------------
APP_PORT=8000
NGINX_PORT=80

# -------------------------------------------------------
# AWS S3 (optional — for file storage)
# -------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -------------------------------------------------------
# Vite (frontend)
# -------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
